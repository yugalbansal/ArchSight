generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// AUTH.JS MODELS
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  
  // ArchSight Relations
  githubInstalls GitHubInstallation[]
  repositories   Repository[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// ARCHITECTURAL ENUMS
// ==========================================

enum ScanStatus {
  pending
  cloning
  detecting
  parsing
  extracting
  completed
  failed
}

enum NodeType {
  Client
  API
  Service
  Worker
  DB
  Queue
  ExternalAPI
  LLM
}

enum RelationType {
  Calls
  Imports
  DBDependency
  AsyncPipeline
}

// ==========================================
// ARCHSIGHT MODELS
// ==========================================

model GitHubInstallation {
  id             String   @id @default(cuid())
  userId         String
  installationId Int
  provider       String   @default("github")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, installationId])
  @@index([installationId])
}

model Repository {
  id        String   @id @default(cuid())
  userId    String
  owner     String
  name      String
  provider  String   @default("github")
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans Scan[]

  @@unique([userId, owner, name])
}

model Scan {
  id           String     @id @default(cuid())
  repositoryId String
  status       ScanStatus // Enum
  progress     Int        @default(0)
  branch       String     @default("main")
  framework    String?
  
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  errorMessage String?
  rawAst       Json?      // Stores the full ExtractedArchitecture JSONB if needed
  
  repository           Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  nodes                ArchitectureNode[]
  edges                ArchitectureEdge[]
  architectureAnalysis ArchitectureAnalysis?

  @@index([repositoryId])
  @@index([status])
}

model ArchitectureNode {
  id       String   @id @default(cuid())
  scanId   String
  type     NodeType // Enum
  name     String
  metadata Json?    // Stores framework-specific info, paths, etc.

  scan    Scan               @relation(fields: [scanId], references: [id], onDelete: Cascade)
  outEdges ArchitectureEdge[] @relation("FromNode")
  inEdges  ArchitectureEdge[] @relation("ToNode")

  @@index([scanId])
  @@index([type])
}

model ArchitectureEdge {
  id           String       @id @default(cuid())
  scanId       String
  fromNodeId   String
  toNodeId     String
  relationType RelationType // Enum

  scan     Scan             @relation(fields: [scanId], references: [id], onDelete: Cascade)
  fromNode ArchitectureNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   ArchitectureNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  
  @@index([scanId])
}

model ArchitectureAnalysis {
  id        String   @id @default(cuid())
  scanId    String   @unique
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  // Architecture insights as JSON - flexible storage
  insights  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("architecture_analyses")
}

